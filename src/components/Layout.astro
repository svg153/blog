---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  isArticle?: boolean;
}

const {
  title,
  description = "Sergio Valverde - Blog sobre Platform Engineering, DevOps, y Agentic Development",
  ogImage,
  isArticle = false,
} = Astro.props;

const socialLinks = [
  { name: 'GitHub', url: 'https://github.com/svg153' },
  { name: 'LinkedIn', url: 'https://linkedin.com/in/svg153' },
  { name: 'X', url: 'https://twitter.com/svg153' },
  { name: 'TikTok', url: 'https://www.tiktok.com/@svg153dev' },
  { name: 'YouTube', url: 'https://www.youtube.com/@svg153' },
];

const socialIcons: Record<string, string> = {
  'GitHub': `<svg height="16" viewBox="0 0 16 16" width="16" aria-hidden="true"><path fill-rule="evenodd" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"></path></svg>`,
  'LinkedIn': `<svg height="16" viewBox="0 0 16 16" width="16"><path fill="currentColor" d="M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854V1.146zm4.943 12.248V6.169H2.542v7.225h2.401zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248-.822 0-1.359.54-1.359 1.248 0 .694.521 1.248 1.327 1.248h.016zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016l.016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225h2.4z"/></svg>`,
  'X': `<svg height="16" viewBox="0 0 16 16" width="16"><path fill="currentColor" d="M12.6.75h2.454l-5.36 6.142L16 15.25h-4.937l-3.867-5.07-4.425 5.07H.316l5.733-6.57L0 .75h5.063l3.495 4.633L12.601.75Zm-.86 13.028h1.36L4.323 2.145H2.865l8.875 11.633Z"/></svg>`,
  'TikTok': '🎵',
  'YouTube': '▶',
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={isArticle ? 'article' : 'website'} />
    <meta property="og:url" content={"https://svg153.github.io/blog" + Astro.url.pathname} />
    <meta name="twitter:card" content="summary_large_image" />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <title>{title} — Sergio Valverde</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
      :root {
        --color-fg-default: #f0f6fc;
        --color-fg-muted: #8b949e;
        --color-fg-subtle: #6e7681;
        --color-canvas-default: #0d1117;
        --color-canvas-subtle: #161b22;
        --color-canvas-inset: #1a1f27;
        --color-border-default: #30363d;
        --color-border-muted: #21262d;
        --color-accent-fg: #58a6ff;
        --color-accent-emphasis: #388bfd;
        --font-stack-text: -apple-system, BlinkMacSystemFont, "Segoe UI", "Noto Sans", Helvetica, Arial, sans-serif;
        --font-stack-mono: ui-monospace, SFMono-Regular, "SF Mono", Menlo, Consolas, "Liberation Mono", monospace;
        --max-width: 1264px;
        --article-width: 720px;
        --card-radius: 8px;
      }
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        font-family: var(--font-stack-text);
        background: var(--color-canvas-default);
        color: var(--color-fg-default);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }
      a { color: var(--color-accent-fg); text-decoration: none; }
      a:hover { text-decoration: underline; }

      /* Header */
      .header {
        background: var(--color-canvas-default);
        border-bottom: 1px solid var(--color-border-default);
        position: sticky;
        top: 0;
        z-index: 100;
      }
      .header-inner {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 16px 32px;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      .header-logo {
        display: flex; align-items: center; gap: 12px;
        font-size: 20px; font-weight: 600; color: var(--color-fg-default);
        text-decoration: none;
      }
      .header-logo:hover { text-decoration: none; }
      .header-logo svg { fill: var(--color-fg-default); }
      .header-nav { display: flex; align-items: center; gap: 24px; }
      .header-nav a {
        color: var(--color-fg-muted); font-size: 14px; font-weight: 500;
        text-decoration: none; transition: color 0.2s;
      }
      .header-nav a:hover { color: var(--color-fg-default); text-decoration: none; }

      /* Footer */
      .footer {
        border-top: 1px solid var(--color-border-default);
        padding: 40px 32px;
        text-align: center;
      }
      .footer-inner { max-width: var(--max-width); margin: 0 auto; }
      .footer-links {
        display: flex; justify-content: center; gap: 24px; margin-bottom: 16px; flex-wrap: wrap;
      }
      .footer-links a { color: var(--color-fg-muted); font-size: 13px; }
      .footer-copy { color: var(--color-fg-muted); font-size: 12px; }

      /* Article content */
      .article-content { font-size: 16px; line-height: 1.8; }
      .article-content h2 {
        font-size: 24px; font-weight: 600;
        margin: 48px 0 16px; padding-bottom: 8px;
        border-bottom: 1px solid var(--color-border-default);
      }
      .article-content h3 {
        font-size: 20px; font-weight: 600;
        margin: 36px 0 12px;
      }
      .article-content p { margin-bottom: 20px; }
      .article-content ul, .article-content ol {
        margin-bottom: 20px; padding-left: 24px;
      }
      .article-content li { margin-bottom: 8px; }
      .article-content a { color: var(--color-accent-fg); text-decoration: underline; }
      .article-content strong { color: var(--color-fg-default); }
      .article-content em { color: var(--color-fg-muted); }

      /* Inline code */
      .article-content code {
        font-family: var(--font-stack-mono);
        background: var(--color-canvas-subtle);
        border: 1px solid var(--color-border-muted);
        padding: 2px 6px;
        border-radius: 5px;
        font-size: 14px;
      }

      /* Code blocks */
      .article-content pre {
        background: var(--color-canvas-subtle);
        border: 1px solid var(--color-border-default);
        border-radius: var(--card-radius);
        padding: 16px 20px;
        overflow-x: auto;
        margin-bottom: 20px;
        position: relative;
      }
      .article-content pre code {
        background: none; border: none; padding: 0;
        font-size: 13px; line-height: 1.6;
        color: var(--color-fg-default);
      }

      /* Blockquote */
      .article-content blockquote {
        border-left: 3px solid var(--color-accent-fg);
        padding-left: 16px;
        margin: 24px 0;
        color: var(--color-fg-muted);
        font-style: italic;
      }

      /* Images */
      .article-content img {
        max-width: 100%;
        border-radius: var(--card-radius);
        margin: 24px 0;
      }

      /* Horizontal rule */
      .article-content hr {
        border: none;
        border-top: 1px solid var(--color-border-default);
        margin: 32px 0;
      }

      /* Tables */
      .article-content table {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 24px;
        font-size: 15px;
      }
      .article-content th, .article-content td {
        border: 1px solid var(--color-border-default);
        padding: 10px 14px;
        text-align: left;
      }
      .article-content th {
        background: var(--color-canvas-subtle);
        font-weight: 600;
        font-size: 14px;
      }
      .article-content td { color: var(--color-fg-muted); }

      /* Tags */
      .tag {
        display: inline-block;
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        padding: 3px 10px;
        border-radius: 20px;
        width: fit-content;
      }
      .tag-ai { color: #f778ba; background: rgba(247, 120, 186, 0.12); }
      .tag-devops { color: #1d9bf0; background: rgba(29, 155, 240, 0.12); }
      .tag-platform { color: #a371f7; background: rgba(163, 113, 247, 0.12); }
      .tag-security { color: #d29922; background: rgba(210, 153, 34, 0.12); }
      .tag-general { color: #3fb950; background: rgba(63, 185, 80, 0.12); }
      .tag-tool { color: #f0883e; background: rgba(240, 136, 62, 0.12); }
      .tag-career { color: #db61a2; background: rgba(219, 97, 162, 0.12); }

      .tag-link {
        font-size: 13px;
        padding: 3px 10px;
        border-radius: 20px;
        border: 1px solid var(--color-border-default);
        color: var(--color-fg-muted);
        text-decoration: none;
        transition: all 0.2s;
      }
      .tag-link:hover {
        border-color: var(--color-fg-muted);
        color: var(--color-fg-default);
        text-decoration: none;
      }

      /* Back link */
      .back-link {
        max-width: var(--article-width);
        margin: 0 auto;
        padding: 24px 32px 0;
      }
      .back-link a {
        color: var(--color-fg-muted);
        font-size: 14px;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: color 0.2s;
      }
      .back-link a:hover { color: var(--color-fg-default); }

      /* Meta */
      .meta {
        font-size: 13px;
        color: var(--color-fg-muted);
        display: flex; align-items: center; gap: 8px; flex-wrap: wrap;
      }
      .meta-dot { width: 4px; height: 4px; border-radius: 50%; background: var(--color-fg-muted); }
      .meta a { color: var(--color-fg-muted); }
      .meta a:hover { color: var(--color-accent-fg); }

      @media (max-width: 768px) {
        .header-inner { padding: 12px 16px; }
        .header-nav { gap: 12px; }
        .header-nav a { font-size: 13px; }
        .footer-inner { padding: 0 16px; }
        .back-link { padding: 16px 16px 0; }
      }
    </style>
  </head>
  <body>
    <header class="header">
      <div class="header-inner">
        <a href="/" class="header-logo">
          <svg height="32" viewBox="0 0 16 16" width="32" aria-hidden="true">
            <path fill-rule="evenodd" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"></path>
          </svg>
          Sergio Valverde
        </a>
        <nav class="header-nav">
          <a href="/">Blog</a>
          <a href="/about/">About</a>
          <a href="https://github.com/svg153" target="_blank" rel="noopener">GitHub</a>
          <a href="https://linkedin.com/in/svg153" target="_blank" rel="noopener">LinkedIn</a>
          <a href="https://twitter.com/svg153" target="_blank" rel="noopener">X</a>
          <a href="https://www.tiktok.com/@svg153dev" target="_blank" rel="noopener">TikTok</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="footer">
      <div class="footer-inner">
        <div class="footer-links">
          {socialLinks.map(link => (
            <a href={link.url} target="_blank" rel="noopener">{link.name}</a>
          ))}
          <a href="/rss.xml">RSS</a>
        </div>
        <p class="footer-copy">© 2025 Sergio Valverde. Built with Astro. Hosted on GitHub Pages.</p>
      </div>
    </footer>
  </body>
</html>
