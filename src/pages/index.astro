---
import Layout from '@layouts/Layout.astro';
import { SITE } from '@config';
import Feed from 'astro:feed';

interface Post {
  title: string;
  date: string;
  description: string;
  slug: string;
  tags: string[];
}

const posts: Post[] = [
  {
    title: 'Mi viaje con el desarrollo agéntico: de Copilot a agentes autónomos',
    date: '2025-06-30',
    description: 'Cómo evolucioné desde usar Copilot como autocompletado hasta construir flujos de trabajo con agentes autónomos que planean, ejecutan y verifican su propio código.',
    slug: 'mi-viaje-agentic-development',
    tags: ['IA', 'agentes', 'Copilot'],
  },
  {
    title: 'GitHub Actions: de CI/CD básico a pipelines de Platform Engineering',
    date: '2025-07-01',
    description: 'De workflows básicos a pipelines completos con reusable workflows, Composite Actions, y un enfoque de Platform Engineering para equipos.',
    slug: 'github-actions-ci-cd-platform-engineering',
    tags: ['DevOps', 'GitHub Actions', 'CI/CD'],
  },
  {
    title: 'Mi stack de herramientas de desarrollo en 2025',
    date: '2025-07-02',
    description: 'Editor, terminal, shell, navegadores, contenedores, IaC y más — las herramientas que uso cada día y por qué las elegí.',
    slug: 'mi-stack-herramientas-2025',
    tags: ['Herramientas', 'Stack'],
  },
];

const sortedPosts = posts.sort((a, b) =>
  new Date(b.date).getTime() - new Date(a.date).getTime()
);

const feedPath = Astro.url.pathname === '/blog/' ? '/blog/rss.xml' : '/rss.xml';
---

<Layout title="Blog" description={SITE.description}>
  <div class="blog-home">
    <header class="blog-hero">
      <h1>Blog</h1>
      <p class="hero-subtitle">
        Opiniones, tutoriales y reflexiones sobre desarrollo, herramientas y tecnología.
        Escritos por <strong>Sergio Valverde</strong> desde Madrid.
      </p>
    </header>

    <div class="post-list">
      {sortedPosts.map((post) => (
        <article class="post-card">
          <header>
            <h2>
              <a href={`/blog/posts/${post.slug}/`}>
                {post.title}
              </a>
            </h2>
            <time class="post-meta" datetime={post.date}>
              {new Date(post.date).toLocaleDateString('es-ES', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              })}
            </time>
          </header>
          <p class="post-description">{post.description}</p>
          <div class="post-tags">
            {post.tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        </article>
      ))}
    </div>

    <footer class="blog-footer">
      <p>
        También publico en{' '}
        <a href="https://dev.to/svg153" target="_blank" rel="noopener">dev.to</a>{' '}
        y{' '}
        <a href="https://linkedin.com/in/svg153" target="_blank" rel="noopener">LinkedIn</a>.
      </p>
    </footer>
  </div>
</Layout>

<style>
  .blog-hero {
    text-align: center;
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .blog-hero h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }

  .hero-subtitle {
    color: var(--color-text-secondary);
    font-size: 1.1rem;
    max-width: 600px;
    margin: 0 auto;
  }

  .post-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .post-card {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1.5rem;
    transition: border-color 0.2s;
  }

  .post-card:hover {
    border-color: var(--color-accent);
  }

  .post-card h2 {
    font-size: 1.35rem;
    margin-bottom: 0.5rem;
  }

  .post-card h2 a {
    color: var(--color-heading);
    text-decoration: none;
  }

  .post-card h2 a:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  .post-meta {
    color: var(--color-text-secondary);
    font-size: 0.85rem;
    font-weight: 500;
  }

  .post-description {
    margin-top: 0.5rem;
    color: var(--color-text);
  }

  .post-tags {
    margin-top: 0.75rem;
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .tag {
    background: rgba(56, 139, 253, 0.15);
    color: var(--color-accent);
    padding: 0.15em 0.6em;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 500;
  }

  .blog-footer {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
    text-align: center;
    color: var(--color-text-secondary);
    font-size: 0.9rem;
  }

  @media (max-width: 640px) {
    .blog-hero h1 {
      font-size: 1.8rem;
    }
    .hero-subtitle {
      font-size: 1rem;
    }
    .post-card {
      padding: 1rem;
    }
  }
</style>
